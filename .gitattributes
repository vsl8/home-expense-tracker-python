# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should use LF line endings
*.sh text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf

# Python files
*.py text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
.dockerignore text eol=lf
